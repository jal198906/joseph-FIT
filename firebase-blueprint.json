{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user basic information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "DailyPlan": {
      "title": "Daily Plan",
      "description": "User's daily diet and exercise plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "dietId": { "type": "string" },
        "exerciseId": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "dietId", "exerciseId", "completed", "userId"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Custom challenges created by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "instructions": { "type": "string" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "instructions", "duration", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/plans/{planId}": {
      "schema": "DailyPlan",
      "description": "User's daily plans subcollection"
    },
    "/users/{userId}/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "User's custom challenges subcollection"
    }
  }
}
